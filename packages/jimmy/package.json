{
  "name": "jinn-cli",
  "version": "0.9.0",
  "description": "Lightweight AI gateway daemon orchestrating Claude Code, Codex, and Gemini CLI",
  "license": "MIT",
  "type": "module",
  "bin": {
    "jinn": "./dist/bin/jimmy.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist/",
    "template/"
  ],
  "scripts": {
    "build": "tsc && rm -rf dist/web && cp -r ../web/out dist/web 2>/dev/null || true",
    "dev": "tsc && (tsc --watch &) && node --watch-path=dist dist/bin/jimmy.js start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@slack/bolt": "^4.3.0",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "better-sqlite3": "^11.8.0",
    "busboy": "^1.6.0",
    "chokidar": "^4.0.0",
    "classic-level": "^2.0.0",
    "commander": "^13.1.0",
    "discord.js": "^14.25.1",
    "js-yaml": "^4.1.0",
    "node-cron": "^3.0.0",
    "node-telegram-bot-api": "^0.67.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "uuid": "^11.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/busboy": "^1.5.4",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.0",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0"
  }
}
