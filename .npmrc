auto-install-peers=true

# --- Node version pinning (prevents the better-sqlite3 ABI mismatch crash) ---
# Force pnpm to run EVERY script + native rebuild under exactly this Node,
# regardless of what's on PATH (the machine also has Homebrew node 25 / ABI 141,
# which silently recompiled better-sqlite3 to the wrong ABI and crashed the gateway).
# This protects all agents/automation: any `pnpm install/add/rebuild` uses 24.13.0.
use-node-version=24.13.0
# Fail loudly if something runs under the wrong Node instead of compiling a bad ABI.
engine-strict=true
